<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_bg_gradient">

    <!-- Decorative Icons (approximate placement) -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="64dp"
        android:layout_marginEnd="48dp"
        android:alpha="0.2"
        android:src="@android:drawable/ic_menu_help"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <!-- Main Flashcard Logo Area -->
    <FrameLayout
        android:id="@+id/logoContainer"
        android:layout_width="200dp"
        android:layout_height="220dp"
        android:layout_marginTop="120dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Yellow Card (Back) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="140dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:layout_marginEnd="40dp"
            android:rotation="-15"
            app:cardBackgroundColor="@color/splash_card_yellow"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp" />

        <!-- Blue Card (Middle) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="140dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:layout_marginEnd="15dp"
            android:rotation="-5"
            app:cardBackgroundColor="@color/splash_card_blue"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp" />

        <!-- White Card (Front) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="140dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:layout_marginStart="15dp"
            android:rotation="10"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/splash_card_yellow" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/splash_blue_top" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="6dp"
                    android:background="@color/splash_blue_top" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/question_mark"
                    android:textColor="@color/splash_blue_top"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- App Title -->
    <LinearLayout
        android:id="@+id/titleGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoContainer">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="@string/flash"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.1"
            android:text="@string/card"
            android:textColor="@color/splash_yellow"
            android:textSize="36sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/quizText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.4"
        android:text="@string/quiz_label"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleGroup" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/tagline"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/quizText" />

    <!-- Progress Section -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/splashProgress"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="120dp"
        android:progress="40"
        app:indicatorColor="@color/splash_yellow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:trackColor="#33000000"
        app:trackCornerRadius="4dp"
        app:trackThickness="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/loading"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/splashProgress" />

    <!-- White Wave at Bottom (Simplified with a View) -->

</androidx.constraintlayout.widget.ConstraintLayout>