<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/chatgpt_image_may_16__2026__10_30_40_pm"
        android:label="@string/app_name"
        android:roundIcon="@drawable/chatgpt_image_may_16__2026__10_30_40_pm"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlashcardQuiz">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FlashcardQuiz">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".AddEditFlashcardActivity"
            android:exported="false"
            android:label="@string/add_flashcard" />

        <activity
            android:name=".StudyActivity"
            android:exported="false"
            android:label="@string/study_mode" />

    </application>

</manifest>